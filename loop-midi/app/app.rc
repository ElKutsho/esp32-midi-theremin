// app.rc — Resource file for Virtual MIDI
#include "resource.h"
#include <winres.h>

// Use default application icon — a custom .ico can be added later
IDI_APPICON ICON "app.ico"

// Version Info
VS_VERSION_INFO VERSIONINFO
FILEVERSION     1,0,0,0
PRODUCTVERSION  1,0,0,0
FILEOS          VOS_NT_WINDOWS32
FILETYPE        VFT_APP
BEGIN
    BLOCK "StringFileInfo"
    BEGIN
        BLOCK "040904B0"
        BEGIN
            VALUE "CompanyName",      "Virtual MIDI Project"
            VALUE "FileDescription",  "Virtual MIDI Loopback"
            VALUE "FileVersion",      "1.0.0"
            VALUE "InternalName",     "VirtualMIDI"
            VALUE "OriginalFilename", "VirtualMIDI.exe"
            VALUE "ProductName",      "Virtual MIDI"
            VALUE "ProductVersion",   "1.0.0"
        END
    END
    BLOCK "VarFileInfo"
    BEGIN
        VALUE "Translation", 0x0409, 1200
    END
END

// Manifest is embedded via CMake linker settings (not here, to avoid mt.exe conflicts)
